//@version=6
indicator("MTA v8.1α-A-B9.1 - NoHTFGate CTL + Fixed + Detach", overlay = true, max_labels_count = 500, max_lines_count = 100, max_bars_back = 5000)

htfTf = input.timeframe("15", "上位足MTA時間足")

leftBars = input.int(6, "15分MTA 左ピボット本数", minval = 1)
rightBars = input.int(6, "15分MTA 右ピボット本数", minval = 1)

triggerLeftBars = input.int(6, "1分CTL 左ピボット本数", minval = 1)
triggerRightBars = input.int(6, "1分CTL 右ピボット本数", minval = 1)

triggerExpireMinutes = input.int(120, "Setup後Trigger有効期限（分）", minval = 1)

showHtfZones = input.bool(true, "15分MTAゾーンを表示")
showHtfPairLines = input.bool(true, "15分MTA対応高値安値を表示")

showCandidateLine = input.bool(true, "常時Candidate CTLラインを表示")
showCandidateLabels = input.bool(true, "常時Candidate CTL H1/H2・L1/L2ラベルを表示")
showFixedLine = input.bool(true, "MTA接触時Fixed CTLラインを表示")
showSetupLabels = input.bool(true, "Setup / Fixedラベルを表示")
showDetachLabels = input.bool(true, "Detach確認ラベルを表示")
showTriggerLabels = input.bool(true, "Triggerラベルを表示")
showInvalidLabels = input.bool(true, "Setup失効ラベルを表示")
showIgnoredPivots = input.bool(false, "CTL不成立Pivotを表示")
showNoCtlSetupLabels = input.bool(false, "CTLなしSetupを表示")
showDebugState = input.bool(false, "状態をデータウィンドウに表示")

useSetupAlerts = input.bool(true, "Setupアラートを有効化")
useTriggerAlerts = input.bool(true, "Triggerアラートを有効化")

bodyHighBreak(targetPrice, rb) =>
    bool result = false
    for i = 0 to rb - 1
        bodyHigh = math.max(open[i], close[i])
        if bodyHigh > targetPrice
            result := true
    result

bodyLowBreak(targetPrice, rb) =>
    bool result = false
    for i = 0 to rb - 1
        bodyLow = math.min(open[i], close[i])
        if bodyLow < targetPrice
            result := true
    result

mtaBodyHighMax(mtaBar) =>
    float result = na
    int barsBack = bar_index - mtaBar
    int limit = math.min(barsBack, 500)
    if limit >= 0
        for i = 0 to limit
            bodyHigh = math.max(open[i], close[i])
            result := na(result) ? bodyHigh : math.max(result, bodyHigh)
    result

mtaBodyLowMin(mtaBar) =>
    float result = na
    int barsBack = bar_index - mtaBar
    int limit = math.min(barsBack, 500)
    if limit >= 0
        for i = 0 to limit
            bodyLow = math.min(open[i], close[i])
            result := na(result) ? bodyLow : math.min(result, bodyLow)
    result

calcHtfMta() =>
    pivotHigh = ta.pivothigh(high, leftBars, rightBars)
    pivotLow = ta.pivotlow(low, leftBars, rightBars)

    isPivotHigh = not na(pivotHigh)
    isPivotLow = not na(pivotLow)

    pivotBar = bar_index - rightBars

    confirmedBodyHigh = math.max(open[1], close[1])
    confirmedBodyLow = math.min(open[1], close[1])
    confirmedHigh = high[1]
    confirmedLow = low[1]

    var int lastType = 0
    var float lastPrice = na
    var float prevHighPrice = na
    var float prevLowPrice = na

    var float lastHighWickPrice = na
    var int lastHighBar = na

    var float lastLowWickPrice = na
    var int lastLowBar = na

    var float currentHighRef = na
    var float currentLowRef = na

    var int trendState = 0

    var float pushLowMtaPrice = na
    var float returnHighMtaPrice = na

    var float pushLowPairHighPrice = na
    var float returnHighPairLowPrice = na

    var float bullZoneTop = na
    var float bullZoneBottom = na

    var float bearZoneTop = na
    var float bearZoneBottom = na

    if trendState == 1 and not na(pushLowPairHighPrice) and confirmedBodyHigh > pushLowPairHighPrice and confirmedHigh > pushLowPairHighPrice
        pushLowPairHighPrice := confirmedHigh
        if not na(lastLowWickPrice)
            pushLowMtaPrice := lastLowWickPrice
            float zoneBodyLow = mtaBodyLowMin(lastLowBar)
            bullZoneTop := zoneBodyLow
            bullZoneBottom := lastLowWickPrice

    if trendState == -1 and not na(returnHighPairLowPrice) and confirmedBodyLow < returnHighPairLowPrice and confirmedLow < returnHighPairLowPrice
        returnHighPairLowPrice := confirmedLow
        if not na(lastHighWickPrice)
            returnHighMtaPrice := lastHighWickPrice
            float zoneBodyHigh = mtaBodyHighMax(lastHighBar)
            bearZoneTop := lastHighWickPrice
            bearZoneBottom := zoneBodyHigh

    if trendState == -1 and not na(returnHighMtaPrice) and close > returnHighMtaPrice
        trendState := 1
        returnHighMtaPrice := na
        returnHighPairLowPrice := na
        bearZoneTop := na
        bearZoneBottom := na

    if trendState == 1 and not na(pushLowMtaPrice) and close < pushLowMtaPrice
        trendState := -1
        pushLowMtaPrice := na
        pushLowPairHighPrice := na
        bullZoneTop := na
        bullZoneBottom := na

    if isPivotHigh
        if lastType == 1
            if pivotHigh > lastPrice
                bool isHH = not na(currentHighRef) and bodyHighBreak(currentHighRef, rightBars)
                lastPrice := pivotHigh
                if isHH and trendState != -1 and na(pushLowMtaPrice) and not na(lastLowWickPrice)
                    trendState := 1
                    pushLowMtaPrice := lastLowWickPrice
                    pushLowPairHighPrice := pivotHigh
                    float zoneBodyLow = mtaBodyLowMin(lastLowBar)
                    bullZoneTop := zoneBodyLow
                    bullZoneBottom := lastLowWickPrice
                prevHighPrice := pivotHigh
                lastHighWickPrice := pivotHigh
                lastHighBar := pivotBar
        else
            currentHighRef := prevHighPrice
            bool isHH = not na(currentHighRef) and bodyHighBreak(currentHighRef, rightBars)
            lastType := 1
            lastPrice := pivotHigh
            if isHH and trendState != -1 and na(pushLowMtaPrice) and not na(lastLowWickPrice)
                trendState := 1
                pushLowMtaPrice := lastLowWickPrice
                pushLowPairHighPrice := pivotHigh
                float zoneBodyLow = mtaBodyLowMin(lastLowBar)
                bullZoneTop := zoneBodyLow
                bullZoneBottom := lastLowWickPrice
            prevHighPrice := pivotHigh
            lastHighWickPrice := pivotHigh
            lastHighBar := pivotBar

    if isPivotLow
        if lastType == -1
            if pivotLow < lastPrice
                bool isLL = not na(currentLowRef) and bodyLowBreak(currentLowRef, rightBars)
                lastPrice := pivotLow
                if isLL and trendState != 1 and na(returnHighMtaPrice) and not na(lastHighWickPrice)
                    trendState := -1
                    returnHighMtaPrice := lastHighWickPrice
                    returnHighPairLowPrice := pivotLow
                    float zoneBodyHigh = mtaBodyHighMax(lastHighBar)
                    bearZoneTop := lastHighWickPrice
                    bearZoneBottom := zoneBodyHigh
                prevLowPrice := pivotLow
                lastLowWickPrice := pivotLow
                lastLowBar := pivotBar
        else
            currentLowRef := prevLowPrice
            bool isLL = not na(currentLowRef) and bodyLowBreak(currentLowRef, rightBars)
            lastType := -1
            lastPrice := pivotLow
            if isLL and trendState != 1 and na(returnHighMtaPrice) and not na(lastHighWickPrice)
                trendState := -1
                returnHighMtaPrice := lastHighWickPrice
                returnHighPairLowPrice := pivotLow
                float zoneBodyHigh = mtaBodyHighMax(lastHighBar)
                bearZoneTop := lastHighWickPrice
                bearZoneBottom := zoneBodyHigh
            prevLowPrice := pivotLow
            lastLowWickPrice := pivotLow
            lastLowBar := pivotBar

    [trendState, bullZoneTop, bullZoneBottom, bearZoneTop, bearZoneBottom, pushLowPairHighPrice, returnHighPairLowPrice]

[htfTrendState, htfBullZoneTop, htfBullZoneBottom, htfBearZoneTop, htfBearZoneBottom, htfBullPairHigh, htfBearPairLow] = request.security(syminfo.tickerid, htfTf, calcHtfMta(), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

htfConfirmedClose = request.security(syminfo.tickerid, htfTf, close[1], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

bullTopPlot = plot(showHtfZones and htfTrendState == 1 ? htfBullZoneTop : na, title = "15m 押し安値MTAゾーン上限", color = color.lime, linewidth = 1, style = plot.style_linebr)
bullBottomPlot = plot(showHtfZones and htfTrendState == 1 ? htfBullZoneBottom : na, title = "15m 押し安値MTAゾーン下限", color = color.lime, linewidth = 1, style = plot.style_linebr)

bearTopPlot = plot(showHtfZones and htfTrendState == -1 ? htfBearZoneTop : na, title = "15m 戻り高値MTAゾーン上限", color = color.aqua, linewidth = 1, style = plot.style_linebr)
bearBottomPlot = plot(showHtfZones and htfTrendState == -1 ? htfBearZoneBottom : na, title = "15m 戻り高値MTAゾーン下限", color = color.aqua, linewidth = 1, style = plot.style_linebr)

fill(bullTopPlot, bullBottomPlot, color = showHtfZones and htfTrendState == 1 ? color.new(color.lime, 85) : na)
fill(bearTopPlot, bearBottomPlot, color = showHtfZones and htfTrendState == -1 ? color.new(color.aqua, 85) : na)

plot(showHtfPairLines and htfTrendState == 1 ? htfBullPairHigh : na, title = "15m MTA対応高値", color = color.orange, linewidth = 2, style = plot.style_linebr)
plot(showHtfPairLines and htfTrendState == -1 ? htfBearPairLow : na, title = "15m MTA対応安値", color = color.red, linewidth = 2, style = plot.style_linebr)

triggerPivotHigh = ta.pivothigh(high, triggerLeftBars, triggerRightBars)
triggerPivotLow = ta.pivotlow(low, triggerLeftBars, triggerRightBars)

isTriggerPivotHigh = not na(triggerPivotHigh)
isTriggerPivotLow = not na(triggerPivotLow)

triggerPivotBar = bar_index - triggerRightBars

bullZoneTouch = htfTrendState == 1 and not na(htfBullZoneTop) and not na(htfBullZoneBottom) and low <= htfBullZoneTop and high >= htfBullZoneBottom
bearZoneTouch = htfTrendState == -1 and not na(htfBearZoneTop) and not na(htfBearZoneBottom) and high >= htfBearZoneBottom and low <= htfBearZoneTop

bullZoneTouchOnce = bullZoneTouch and not bullZoneTouch[1]
bearZoneTouchOnce = bearZoneTouch and not bearZoneTouch[1]

var float longLastH = na
var int longLastHBar = na
var float shortLastL = na
var int shortLastLBar = na

var float longCandidateH1 = na
var int longCandidateH1Bar = na
var float longCandidateH2 = na
var int longCandidateH2Bar = na
var float longCandidateSlope = na
var bool longCandidateReady = false

var float shortCandidateL1 = na
var int shortCandidateL1Bar = na
var float shortCandidateL2 = na
var int shortCandidateL2Bar = na
var float shortCandidateSlope = na
var bool shortCandidateReady = false

var float longFixedH1 = na
var int longFixedH1Bar = na
var float longFixedH2 = na
var int longFixedH2Bar = na
var float longFixedSlope = na
var bool longFixedReady = false
var bool longFixedDetached = false

var float shortFixedL1 = na
var int shortFixedL1Bar = na
var float shortFixedL2 = na
var int shortFixedL2Bar = na
var float shortFixedSlope = na
var bool shortFixedReady = false
var bool shortFixedDetached = false

var bool longSetupActive = false
var bool shortSetupActive = false
var bool longTriggerFired = false
var bool shortTriggerFired = false

var int longSetupTime = na
var int shortSetupTime = na

var float setupBullInvalidLevel = na
var float setupBearInvalidLevel = na

var line longCandidateLine = na
var line shortCandidateLine = na
var line longFixedLine = na
var line shortFixedLine = na

var label longCandidateH1Label = na
var label longCandidateH2Label = na
var label shortCandidateL1Label = na
var label shortCandidateL2Label = na
var label setupLabel = na
var label longDetachLabel = na
var label shortDetachLabel = na

expireMs = triggerExpireMinutes * 60 * 1000

deleteLongFixedObjects() =>
    if not na(longFixedLine)
        line.delete(longFixedLine)
    if not na(longDetachLabel)
        label.delete(longDetachLabel)

deleteShortFixedObjects() =>
    if not na(shortFixedLine)
        line.delete(shortFixedLine)
    if not na(shortDetachLabel)
        label.delete(shortDetachLabel)

if barstate.isconfirmed and isTriggerPivotHigh
    if na(longLastH)
        longLastH := triggerPivotHigh
        longLastHBar := triggerPivotBar
        if showCandidateLabels
            if not na(longCandidateH1Label)
                label.delete(longCandidateH1Label)
                longCandidateH1Label := na
            longCandidateH1Label := label.new(longLastHBar, longLastH, "Candidate H1", style = label.style_label_down, textcolor = color.white, color = color.orange, size = size.tiny)
    else
        if triggerPivotHigh < longLastH
            longCandidateH1 := longLastH
            longCandidateH1Bar := longLastHBar
            longCandidateH2 := triggerPivotHigh
            longCandidateH2Bar := triggerPivotBar
            if longCandidateH2Bar > longCandidateH1Bar
                longCandidateSlope := (longCandidateH2 - longCandidateH1) / (longCandidateH2Bar - longCandidateH1Bar)
                longCandidateReady := true
                if not na(longCandidateLine)
                    line.delete(longCandidateLine)
                    longCandidateLine := na
                if showCandidateLine
                    longCandidateLine := line.new(longCandidateH1Bar, longCandidateH1, longCandidateH2Bar, longCandidateH2, extend = extend.right, color = color.orange, width = 2)
                if showCandidateLabels
                    if not na(longCandidateH1Label)
                        label.delete(longCandidateH1Label)
                        longCandidateH1Label := na
                    if not na(longCandidateH2Label)
                        label.delete(longCandidateH2Label)
                        longCandidateH2Label := na
                    longCandidateH1Label := label.new(longCandidateH1Bar, longCandidateH1, "Candidate H1", style = label.style_label_down, textcolor = color.white, color = color.orange, size = size.tiny)
                    longCandidateH2Label := label.new(longCandidateH2Bar, longCandidateH2, "Candidate H2", style = label.style_label_down, textcolor = color.white, color = color.orange, size = size.tiny)
            longLastH := triggerPivotHigh
            longLastHBar := triggerPivotBar
        else
            if showIgnoredPivots
                label.new(triggerPivotBar, triggerPivotHigh, "H NG\nnew H1", style = label.style_label_down, textcolor = color.white, color = color.gray, size = size.tiny)
            longLastH := triggerPivotHigh
            longLastHBar := triggerPivotBar
            if showCandidateLabels
                if not na(longCandidateH1Label)
                    label.delete(longCandidateH1Label)
                    longCandidateH1Label := na
                longCandidateH1Label := label.new(longLastHBar, longLastH, "Candidate H1", style = label.style_label_down, textcolor = color.white, color = color.orange, size = size.tiny)

if barstate.isconfirmed and isTriggerPivotLow
    if na(shortLastL)
        shortLastL := triggerPivotLow
        shortLastLBar := triggerPivotBar
        if showCandidateLabels
            if not na(shortCandidateL1Label)
                label.delete(shortCandidateL1Label)
                shortCandidateL1Label := na
            shortCandidateL1Label := label.new(shortLastLBar, shortLastL, "Candidate L1", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.tiny)
    else
        if triggerPivotLow > shortLastL
            shortCandidateL1 := shortLastL
            shortCandidateL1Bar := shortLastLBar
            shortCandidateL2 := triggerPivotLow
            shortCandidateL2Bar := triggerPivotBar
            if shortCandidateL2Bar > shortCandidateL1Bar
                shortCandidateSlope := (shortCandidateL2 - shortCandidateL1) / (shortCandidateL2Bar - shortCandidateL1Bar)
                shortCandidateReady := true
                if not na(shortCandidateLine)
                    line.delete(shortCandidateLine)
                    shortCandidateLine := na
                if showCandidateLine
                    shortCandidateLine := line.new(shortCandidateL1Bar, shortCandidateL1, shortCandidateL2Bar, shortCandidateL2, extend = extend.right, color = color.red, width = 2)
                if showCandidateLabels
                    if not na(shortCandidateL1Label)
                        label.delete(shortCandidateL1Label)
                        shortCandidateL1Label := na
                    if not na(shortCandidateL2Label)
                        label.delete(shortCandidateL2Label)
                        shortCandidateL2Label := na
                    shortCandidateL1Label := label.new(shortCandidateL1Bar, shortCandidateL1, "Candidate L1", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.tiny)
                    shortCandidateL2Label := label.new(shortCandidateL2Bar, shortCandidateL2, "Candidate L2", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.tiny)
            shortLastL := triggerPivotLow
            shortLastLBar := triggerPivotBar
        else
            if showIgnoredPivots
                label.new(triggerPivotBar, triggerPivotLow, "L NG\nnew L1", style = label.style_label_up, textcolor = color.white, color = color.gray, size = size.tiny)
            shortLastL := triggerPivotLow
            shortLastLBar := triggerPivotBar
            if showCandidateLabels
                if not na(shortCandidateL1Label)
                    label.delete(shortCandidateL1Label)
                    shortCandidateL1Label := na
                shortCandidateL1Label := label.new(shortLastLBar, shortLastL, "Candidate L1", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.tiny)

if barstate.isconfirmed and bullZoneTouchOnce
    if longCandidateReady
        longSetupActive := true
        shortSetupActive := false
        longTriggerFired := false
        shortTriggerFired := false
        longSetupTime := time
        shortSetupTime := na
        setupBullInvalidLevel := htfBullZoneBottom
        setupBearInvalidLevel := na
        longFixedReady := true
        shortFixedReady := false
        longFixedDetached := false
        shortFixedDetached := false
        longFixedH1 := longCandidateH1
        longFixedH1Bar := longCandidateH1Bar
        longFixedH2 := longCandidateH2
        longFixedH2Bar := longCandidateH2Bar
        longFixedSlope := longCandidateSlope
        deleteLongFixedObjects()
        longFixedLine := na
        longDetachLabel := na
        if showFixedLine
            longFixedLine := line.new(longFixedH1Bar, longFixedH1, longFixedH2Bar, longFixedH2, extend = extend.right, color = color.yellow, width = 2)
        if not na(setupLabel)
            label.delete(setupLabel)
            setupLabel := na
        if showSetupLabels
            setupLabel := label.new(bar_index, low, "Long Setup\nLatest CTL Fixed", style = label.style_label_up, textcolor = color.white, color = color.green, size = size.small)
    else
        if showNoCtlSetupLabels
            label.new(bar_index, low, "Long Setup\nNo Candidate CTL", style = label.style_label_up, textcolor = color.white, color = color.gray, size = size.small)

if barstate.isconfirmed and bearZoneTouchOnce
    if shortCandidateReady
        shortSetupActive := true
        longSetupActive := false
        shortTriggerFired := false
        longTriggerFired := false
        shortSetupTime := time
        longSetupTime := na
        setupBearInvalidLevel := htfBearZoneTop
        setupBullInvalidLevel := na
        shortFixedReady := true
        longFixedReady := false
        shortFixedDetached := false
        longFixedDetached := false
        shortFixedL1 := shortCandidateL1
        shortFixedL1Bar := shortCandidateL1Bar
        shortFixedL2 := shortCandidateL2
        shortFixedL2Bar := shortCandidateL2Bar
        shortFixedSlope := shortCandidateSlope
        deleteShortFixedObjects()
        shortFixedLine := na
        shortDetachLabel := na
        if showFixedLine
            shortFixedLine := line.new(shortFixedL1Bar, shortFixedL1, shortFixedL2Bar, shortFixedL2, extend = extend.right, color = color.yellow, width = 2)
        if not na(setupLabel)
            label.delete(setupLabel)
            setupLabel := na
        if showSetupLabels
            setupLabel := label.new(bar_index, high, "Short Setup\nLatest CTL Fixed", style = label.style_label_down, textcolor = color.white, color = color.red, size = size.small)
    else
        if showNoCtlSetupLabels
            label.new(bar_index, high, "Short Setup\nNo Candidate CTL", style = label.style_label_down, textcolor = color.white, color = color.gray, size = size.small)

longExpired = longSetupActive and not na(longSetupTime) and time - longSetupTime > expireMs
shortExpired = shortSetupActive and not na(shortSetupTime) and time - shortSetupTime > expireMs

if barstate.isconfirmed and longExpired
    longSetupActive := false
    setupBullInvalidLevel := na
    longFixedReady := false
    longFixedDetached := false
    deleteLongFixedObjects()
    longFixedLine := na
    longDetachLabel := na
    if showInvalidLabels
        label.new(bar_index, close, "Long Setup Expired", style = label.style_label_left, textcolor = color.white, color = color.gray, size = size.small)

if barstate.isconfirmed and shortExpired
    shortSetupActive := false
    setupBearInvalidLevel := na
    shortFixedReady := false
    shortFixedDetached := false
    deleteShortFixedObjects()
    shortFixedLine := na
    shortDetachLabel := na
    if showInvalidLabels
        label.new(bar_index, close, "Short Setup Expired", style = label.style_label_left, textcolor = color.white, color = color.gray, size = size.small)

longInvalid = longSetupActive and not na(setupBullInvalidLevel) and htfConfirmedClose < setupBullInvalidLevel
shortInvalid = shortSetupActive and not na(setupBearInvalidLevel) and htfConfirmedClose > setupBearInvalidLevel

if barstate.isconfirmed and longInvalid
    longSetupActive := false
    setupBullInvalidLevel := na
    longFixedReady := false
    longFixedDetached := false
    deleteLongFixedObjects()
    longFixedLine := na
    longDetachLabel := na
    if showInvalidLabels
        label.new(bar_index, low, "Long Setup Invalid\n15m Confirmed Close", style = label.style_label_up, textcolor = color.white, color = color.gray, size = size.small)

if barstate.isconfirmed and shortInvalid
    shortSetupActive := false
    setupBearInvalidLevel := na
    shortFixedReady := false
    shortFixedDetached := false
    deleteShortFixedObjects()
    shortFixedLine := na
    shortDetachLabel := na
    if showInvalidLabels
        label.new(bar_index, high, "Short Setup Invalid\n15m Confirmed Close", style = label.style_label_down, textcolor = color.white, color = color.gray, size = size.small)

float longFixedCtlPrice = na
float shortFixedCtlPrice = na

if longFixedReady and not na(longFixedH2) and not na(longFixedH2Bar) and not na(longFixedSlope)
    longFixedCtlPrice := longFixedH2 + longFixedSlope * (bar_index - longFixedH2Bar)

if shortFixedReady and not na(shortFixedL2) and not na(shortFixedL2Bar) and not na(shortFixedSlope)
    shortFixedCtlPrice := shortFixedL2 + shortFixedSlope * (bar_index - shortFixedL2Bar)

if barstate.isconfirmed and longSetupActive and longFixedReady and not longFixedDetached and not na(longFixedCtlPrice) and high < longFixedCtlPrice
    longFixedDetached := true
    if showDetachLabels
        longDetachLabel := label.new(bar_index, high, "Long CTL Detached", style = label.style_label_down, textcolor = color.white, color = color.purple, size = size.tiny)

if barstate.isconfirmed and shortSetupActive and shortFixedReady and not shortFixedDetached and not na(shortFixedCtlPrice) and low > shortFixedCtlPrice
    shortFixedDetached := true
    if showDetachLabels
        shortDetachLabel := label.new(bar_index, low, "Short CTL Detached", style = label.style_label_up, textcolor = color.white, color = color.purple, size = size.tiny)

longTrigger = false
shortTrigger = false

currentBodyHigh = math.max(open, close)
currentBodyLow = math.min(open, close)

if barstate.isconfirmed and longSetupActive and not longTriggerFired and longFixedReady and longFixedDetached and not na(longFixedCtlPrice) and currentBodyHigh > longFixedCtlPrice
    longTrigger := true
    longTriggerFired := true
    longSetupActive := false
    setupBullInvalidLevel := na
    longFixedReady := false
    longFixedDetached := false
    if showTriggerLabels
        label.new(bar_index, high, "Long Trigger\nNoHTFGate Fixed CTL Detach Break", style = label.style_label_down, textcolor = color.white, color = color.green, size = size.normal)

if barstate.isconfirmed and shortSetupActive and not shortTriggerFired and shortFixedReady and shortFixedDetached and not na(shortFixedCtlPrice) and currentBodyLow < shortFixedCtlPrice
    shortTrigger := true
    shortTriggerFired := true
    shortSetupActive := false
    setupBearInvalidLevel := na
    shortFixedReady := false
    shortFixedDetached := false
    if showTriggerLabels
        label.new(bar_index, low, "Short Trigger\nNoHTFGate Fixed CTL Detach Break", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.normal)

alertcondition(useSetupAlerts and bullZoneTouchOnce and longCandidateReady, title = "Long Setup B9.1", message = "15分Bull MTAゾーン接触。最新の常時Long候補CTLをFixed化しました")
alertcondition(useSetupAlerts and bearZoneTouchOnce and shortCandidateReady, title = "Short Setup B9.1", message = "15分Bear MTAゾーン接触。最新の常時Short候補CTLをFixed化しました")
alertcondition(useTriggerAlerts and longTrigger, title = "Long Trigger B9.1 NoHTFGate CTL", message = "Long Setup後、NoHTFGate Fixed CTLから一度離れた後、1分足実体で上抜けしました")
alertcondition(useTriggerAlerts and shortTrigger, title = "Short Trigger B9.1 NoHTFGate CTL", message = "Short Setup後、NoHTFGate Fixed CTLから一度離れた後、1分足実体で下抜けしました")

plot(showDebugState ? htfTrendState : na, title = "HTF Trend State", display = display.data_window)
plot(showDebugState ? (longCandidateReady ? 1 : 0) : na, title = "Long Candidate Ready", display = display.data_window)
plot(showDebugState ? (shortCandidateReady ? 1 : 0) : na, title = "Short Candidate Ready", display = display.data_window)
plot(showDebugState ? (longFixedReady ? 1 : 0) : na, title = "Long Fixed Ready", display = display.data_window)
plot(showDebugState ? (shortFixedReady ? 1 : 0) : na, title = "Short Fixed Ready", display = display.data_window)
plot(showDebugState ? (longFixedDetached ? 1 : 0) : na, title = "Long Fixed Detached", display = display.data_window)
plot(showDebugState ? (shortFixedDetached ? 1 : 0) : na, title = "Short Fixed Detached", display = display.data_window)
