//@version=6
strategy("MTA v8.1α-G-S1.1-EMA Filter Strategy SL Mode Test - 15m/1H MTA on Trigger TF", overlay = true, initial_capital = 1000000, default_qty_type = strategy.percent_of_equity, default_qty_value = 2, commission_type = strategy.commission.percent, commission_value = 0.04, slippage = 2, pyramiding = 0, process_orders_on_close = false, calc_on_every_tick = false, max_labels_count = 500, max_lines_count = 100, max_bars_back = 5000)

htfTf = input.timeframe("60", "上位足MTA時間足")

leftBars = input.int(3, "上位足MTA 左ピボット本数", minval = 1)
rightBars = input.int(3, "上位足MTA 右ピボット本数", minval = 1)

triggerLeftBars = input.int(10, "Trigger 左ピボット本数", minval = 1)
triggerRightBars = input.int(10, "Trigger 右ピボット本数", minval = 1)
triggerExpireMinutes = input.int(120, "Trigger有効期限（分）", minval = 1)

rr = input.float(1.3, "利確RR", minval = 0.1, step = 0.1)
slMode = input.string("MTA Zone", "SL Mode", options = ["MTA Zone", "Trigger Bar", "Setup Touch Bar", "MTA Zone Mid"])

showHtfZones = input.bool(true, "上位足MTAゾーンを表示")
showHtfPairLines = input.bool(true, "上位足MTA対応高値安値を表示")
showTrendStatePlot = input.bool(false, "MTA状態をデータウィンドウに表示")

showEma = input.bool(true, "Trigger足EMAを表示")
emaLen = input.int(20, "Trigger足EMA期間", minval = 1)

useEmaFilter = input.bool(true, "EMA Filterを有効化")
showSetupLabels = input.bool(true, "Setupラベルを表示")
showTriggerLabels = input.bool(true, "Triggerラベルを表示")
showInvalidLabels = input.bool(true, "Setup失効/Filter NGラベルを表示")
showTriggerPivots = input.bool(true, "Trigger基準H/Lを表示")
showFilterStatePlot = input.bool(false, "EMA Filter状態をデータウィンドウに表示")

useZoneTouchAlerts = input.bool(true, "MTAゾーン接触アラートを有効化")
useTriggerAlerts = input.bool(true, "EMA Filter Triggerアラートを有効化")

bodyHighBreak(targetPrice, rb) =>
    bool result = false
    for i = 0 to rb - 1
        bodyHigh = math.max(open[i], close[i])
        if bodyHigh > targetPrice
            result := true
    result

bodyLowBreak(targetPrice, rb) =>
    bool result = false
    for i = 0 to rb - 1
        bodyLow = math.min(open[i], close[i])
        if bodyLow < targetPrice
            result := true
    result

mtaBodyHighMax(mtaBar) =>
    float result = na
    int barsBack = bar_index - mtaBar
    int limit = math.min(barsBack, 500)
    if limit >= 0
        for i = 0 to limit
            bodyHigh = math.max(open[i], close[i])
            result := na(result) ? bodyHigh : math.max(result, bodyHigh)
    result

mtaBodyLowMin(mtaBar) =>
    float result = na
    int barsBack = bar_index - mtaBar
    int limit = math.min(barsBack, 500)
    if limit >= 0
        for i = 0 to limit
            bodyLow = math.min(open[i], close[i])
            result := na(result) ? bodyLow : math.min(result, bodyLow)
    result

calcHtfMta() =>
    pivotHigh = ta.pivothigh(high, leftBars, rightBars)
    pivotLow = ta.pivotlow(low, leftBars, rightBars)

    isPivotHigh = not na(pivotHigh)
    isPivotLow = not na(pivotLow)

    pivotBar = bar_index - rightBars

    confirmedBodyHigh = math.max(open[1], close[1])
    confirmedBodyLow = math.min(open[1], close[1])
    confirmedHigh = high[1]
    confirmedLow = low[1]

    var int lastType = 0
    var float lastPrice = na
    var float prevHighPrice = na
    var float prevLowPrice = na

    var float lastHighWickPrice = na
    var int lastHighBar = na

    var float lastLowWickPrice = na
    var int lastLowBar = na

    var float currentHighRef = na
    var float currentLowRef = na

    var int trendState = 0

    var float pushLowMtaPrice = na
    var float returnHighMtaPrice = na

    var float pushLowPairHighPrice = na
    var float returnHighPairLowPrice = na

    var float bullZoneTop = na
    var float bullZoneBottom = na

    var float bearZoneTop = na
    var float bearZoneBottom = na

    if trendState == 1 and not na(pushLowPairHighPrice) and confirmedBodyHigh > pushLowPairHighPrice and confirmedHigh > pushLowPairHighPrice
        pushLowPairHighPrice := confirmedHigh
        if not na(lastLowWickPrice)
            pushLowMtaPrice := lastLowWickPrice
            float zoneBodyLow = mtaBodyLowMin(lastLowBar)
            bullZoneTop := zoneBodyLow
            bullZoneBottom := lastLowWickPrice

    if trendState == -1 and not na(returnHighPairLowPrice) and confirmedBodyLow < returnHighPairLowPrice and confirmedLow < returnHighPairLowPrice
        returnHighPairLowPrice := confirmedLow
        if not na(lastHighWickPrice)
            returnHighMtaPrice := lastHighWickPrice
            float zoneBodyHigh = mtaBodyHighMax(lastHighBar)
            bearZoneTop := lastHighWickPrice
            bearZoneBottom := zoneBodyHigh

    if trendState == -1 and not na(returnHighMtaPrice) and close > returnHighMtaPrice
        trendState := 1
        returnHighMtaPrice := na
        returnHighPairLowPrice := na
        bearZoneTop := na
        bearZoneBottom := na

    if trendState == 1 and not na(pushLowMtaPrice) and close < pushLowMtaPrice
        trendState := -1
        pushLowMtaPrice := na
        pushLowPairHighPrice := na
        bullZoneTop := na
        bullZoneBottom := na

    if isPivotHigh
        if lastType == 1
            if pivotHigh > lastPrice
                bool isHH = not na(currentHighRef) and bodyHighBreak(currentHighRef, rightBars)
                lastPrice := pivotHigh
                if isHH and trendState != -1 and na(pushLowMtaPrice) and not na(lastLowWickPrice)
                    trendState := 1
                    pushLowMtaPrice := lastLowWickPrice
                    pushLowPairHighPrice := pivotHigh
                    float zoneBodyLow = mtaBodyLowMin(lastLowBar)
                    bullZoneTop := zoneBodyLow
                    bullZoneBottom := lastLowWickPrice
                prevHighPrice := pivotHigh
                lastHighWickPrice := pivotHigh
                lastHighBar := pivotBar
        else
            currentHighRef := prevHighPrice
            bool isHH = not na(currentHighRef) and bodyHighBreak(currentHighRef, rightBars)
            lastType := 1
            lastPrice := pivotHigh
            if isHH and trendState != -1 and na(pushLowMtaPrice) and not na(lastLowWickPrice)
                trendState := 1
                pushLowMtaPrice := lastLowWickPrice
                pushLowPairHighPrice := pivotHigh
                float zoneBodyLow = mtaBodyLowMin(lastLowBar)
                bullZoneTop := zoneBodyLow
                bullZoneBottom := lastLowWickPrice
            prevHighPrice := pivotHigh
            lastHighWickPrice := pivotHigh
            lastHighBar := pivotBar

    if isPivotLow
        if lastType == -1
            if pivotLow < lastPrice
                bool isLL = not na(currentLowRef) and bodyLowBreak(currentLowRef, rightBars)
                lastPrice := pivotLow
                if isLL and trendState != 1 and na(returnHighMtaPrice) and not na(lastHighWickPrice)
                    trendState := -1
                    returnHighMtaPrice := lastHighWickPrice
                    returnHighPairLowPrice := pivotLow
                    float zoneBodyHigh = mtaBodyHighMax(lastHighBar)
                    bearZoneTop := lastHighWickPrice
                    bearZoneBottom := zoneBodyHigh
                prevLowPrice := pivotLow
                lastLowWickPrice := pivotLow
                lastLowBar := pivotBar
        else
            currentLowRef := prevLowPrice
            bool isLL = not na(currentLowRef) and bodyLowBreak(currentLowRef, rightBars)
            lastType := -1
            lastPrice := pivotLow
            if isLL and trendState != 1 and na(returnHighMtaPrice) and not na(lastHighWickPrice)
                trendState := -1
                returnHighMtaPrice := lastHighWickPrice
                returnHighPairLowPrice := pivotLow
                float zoneBodyHigh = mtaBodyHighMax(lastHighBar)
                bearZoneTop := lastHighWickPrice
                bearZoneBottom := zoneBodyHigh
            prevLowPrice := pivotLow
            lastLowWickPrice := pivotLow
            lastLowBar := pivotBar

    [trendState, bullZoneTop, bullZoneBottom, bearZoneTop, bearZoneBottom, pushLowPairHighPrice, returnHighPairLowPrice]

[htfTrendState, htfBullZoneTop, htfBullZoneBottom, htfBearZoneTop, htfBearZoneBottom, htfBullPairHigh, htfBearPairLow] = request.security(syminfo.tickerid, htfTf, calcHtfMta(), gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

htfClose = request.security(syminfo.tickerid, htfTf, close, gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

bullTopPlot = plot(showHtfZones and htfTrendState == 1 ? htfBullZoneTop : na, title = "HTF 押し安値MTAゾーン上限", color = color.lime, linewidth = 1, style = plot.style_linebr)
bullBottomPlot = plot(showHtfZones and htfTrendState == 1 ? htfBullZoneBottom : na, title = "HTF 押し安値MTAゾーン下限", color = color.lime, linewidth = 1, style = plot.style_linebr)

bearTopPlot = plot(showHtfZones and htfTrendState == -1 ? htfBearZoneTop : na, title = "HTF 戻り高値MTAゾーン上限", color = color.aqua, linewidth = 1, style = plot.style_linebr)
bearBottomPlot = plot(showHtfZones and htfTrendState == -1 ? htfBearZoneBottom : na, title = "HTF 戻り高値MTAゾーン下限", color = color.aqua, linewidth = 1, style = plot.style_linebr)

fill(bullTopPlot, bullBottomPlot, color = showHtfZones and htfTrendState == 1 ? color.new(color.lime, 85) : na)
fill(bearTopPlot, bearBottomPlot, color = showHtfZones and htfTrendState == -1 ? color.new(color.aqua, 85) : na)

plot(showHtfPairLines and htfTrendState == 1 ? htfBullPairHigh : na, title = "HTF MTA対応高値", color = color.orange, linewidth = 2, style = plot.style_linebr)
plot(showHtfPairLines and htfTrendState == -1 ? htfBearPairLow : na, title = "HTF MTA対応安値", color = color.red, linewidth = 2, style = plot.style_linebr)

plot(showTrendStatePlot ? htfTrendState : na, title = "HTF MTA State", display = display.data_window)

emaValue = ta.ema(close, emaLen)

plot(showEma ? emaValue : na, title = "Trigger TF EMA", color = color.yellow, linewidth = 2)

triggerPivotHigh = ta.pivothigh(high, triggerLeftBars, triggerRightBars)
triggerPivotLow = ta.pivotlow(low, triggerLeftBars, triggerRightBars)

isTriggerPivotHigh = not na(triggerPivotHigh)
isTriggerPivotLow = not na(triggerPivotLow)

triggerPivotBar = bar_index - triggerRightBars

var float latestPivotHigh = na
var int latestPivotHighBar = na
var float latestPivotLow = na
var int latestPivotLowBar = na

if isTriggerPivotHigh
    latestPivotHigh := triggerPivotHigh
    latestPivotHighBar := triggerPivotBar

if isTriggerPivotLow
    latestPivotLow := triggerPivotLow
    latestPivotLowBar := triggerPivotBar

bullZoneTouch = htfTrendState == 1 and not na(htfBullZoneTop) and not na(htfBullZoneBottom) and low <= htfBullZoneTop and high >= htfBullZoneBottom
bearZoneTouch = htfTrendState == -1 and not na(htfBearZoneTop) and not na(htfBearZoneBottom) and high >= htfBearZoneBottom and low <= htfBearZoneTop

bullZoneTouchOnce = bullZoneTouch and not bullZoneTouch[1]
bearZoneTouchOnce = bearZoneTouch and not bearZoneTouch[1]

var bool longSetupActive = false
var bool shortSetupActive = false
var bool longTriggerFired = false
var bool shortTriggerFired = false
var int longSetupTime = na
var int shortSetupTime = na

var float longBreakHigh = na
var int longBreakHighBar = na
var float shortBreakLow = na
var int shortBreakLowBar = na

var float setupBullInvalidLevel = na
var float setupBearInvalidLevel = na

var float longSetupTouchLow = na
var float shortSetupTouchHigh = na

var label setupLabel = na
var label longBreakLabel = na
var label shortBreakLabel = na

expireMs = triggerExpireMinutes * 60 * 1000

if bullZoneTouchOnce
    longSetupActive := true
    shortSetupActive := false
    longTriggerFired := false
    shortTriggerFired := false
    longSetupTime := time
    shortSetupTime := na
    longBreakHigh := latestPivotHigh
    longBreakHighBar := latestPivotHighBar
    shortBreakLow := na
    shortBreakLowBar := na
    setupBullInvalidLevel := htfBullZoneBottom
    setupBearInvalidLevel := na
    longSetupTouchLow := low
    shortSetupTouchHigh := na
    if not na(setupLabel)
        label.delete(setupLabel)
        setupLabel := na
    if not na(longBreakLabel)
        label.delete(longBreakLabel)
        longBreakLabel := na
    if not na(shortBreakLabel)
        label.delete(shortBreakLabel)
        shortBreakLabel := na
    if showSetupLabels
        setupLabel := label.new(bar_index, low, "L Setup\nHTF MTA接触", style = label.style_label_up, textcolor = color.white, color = color.green, size = size.small)
    if showTriggerPivots
        if not na(longBreakHigh)
            if not na(longBreakHighBar)
                longBreakLabel := label.new(longBreakHighBar, longBreakHigh, "Pre Break H", style = label.style_label_down, textcolor = color.white, color = color.orange, size = size.tiny)

if bearZoneTouchOnce
    shortSetupActive := true
    longSetupActive := false
    shortTriggerFired := false
    longTriggerFired := false
    shortSetupTime := time
    longSetupTime := na
    shortBreakLow := latestPivotLow
    shortBreakLowBar := latestPivotLowBar
    longBreakHigh := na
    longBreakHighBar := na
    setupBearInvalidLevel := htfBearZoneTop
    setupBullInvalidLevel := na
    shortSetupTouchHigh := high
    longSetupTouchLow := na
    if not na(setupLabel)
        label.delete(setupLabel)
        setupLabel := na
    if not na(longBreakLabel)
        label.delete(longBreakLabel)
        longBreakLabel := na
    if not na(shortBreakLabel)
        label.delete(shortBreakLabel)
        shortBreakLabel := na
    if showSetupLabels
        setupLabel := label.new(bar_index, high, "S Setup\nHTF MTA接触", style = label.style_label_down, textcolor = color.white, color = color.red, size = size.small)
    if showTriggerPivots
        if not na(shortBreakLow)
            if not na(shortBreakLowBar)
                shortBreakLabel := label.new(shortBreakLowBar, shortBreakLow, "Pre Break L", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.tiny)

longExpired = longSetupActive and not na(longSetupTime) and time - longSetupTime > expireMs
shortExpired = shortSetupActive and not na(shortSetupTime) and time - shortSetupTime > expireMs

if longExpired
    longSetupActive := false
    setupBullInvalidLevel := na
    longSetupTouchLow := na
    if showInvalidLabels
        label.new(bar_index, close, "L Setup Expired", style = label.style_label_left, textcolor = color.white, color = color.gray, size = size.small)

if shortExpired
    shortSetupActive := false
    setupBearInvalidLevel := na
    shortSetupTouchHigh := na
    if showInvalidLabels
        label.new(bar_index, close, "S Setup Expired", style = label.style_label_left, textcolor = color.white, color = color.gray, size = size.small)

longInvalid = longSetupActive and not na(setupBullInvalidLevel) and htfClose < setupBullInvalidLevel
shortInvalid = shortSetupActive and not na(setupBearInvalidLevel) and htfClose > setupBearInvalidLevel

if longInvalid
    longSetupActive := false
    setupBullInvalidLevel := na
    longSetupTouchLow := na
    if showInvalidLabels
        label.new(bar_index, low, "L Setup Invalid\nHTF Close", style = label.style_label_up, textcolor = color.white, color = color.gray, size = size.small)

if shortInvalid
    shortSetupActive := false
    setupBearInvalidLevel := na
    shortSetupTouchHigh := na
    if showInvalidLabels
        label.new(bar_index, high, "S Setup Invalid\nHTF Close", style = label.style_label_down, textcolor = color.white, color = color.gray, size = size.small)

currentBodyHigh = math.max(open, close)
currentBodyLow = math.min(open, close)

longPivotBreak = false
shortPivotBreak = false

if longSetupActive
    if not longTriggerFired
        if not na(longBreakHigh)
            if barstate.isconfirmed
                if currentBodyHigh > longBreakHigh
                    longPivotBreak := true

if shortSetupActive
    if not shortTriggerFired
        if not na(shortBreakLow)
            if barstate.isconfirmed
                if currentBodyLow < shortBreakLow
                    shortPivotBreak := true

longEmaFilterOk = close > emaValue
shortEmaFilterOk = close < emaValue

longTrigger = false
shortTrigger = false

longFilterNg = false
shortFilterNg = false

if longPivotBreak
    longTriggerFired := true
    longSetupActive := false
    setupBullInvalidLevel := na
    if useEmaFilter
        if longEmaFilterOk
            longTrigger := true
            if showTriggerLabels
                label.new(bar_index, high, "L Trigger\nPre H Body Break\nEMA Filter OK", style = label.style_label_down, textcolor = color.white, color = color.green, size = size.normal)
        else
            longFilterNg := true
            longSetupTouchLow := na
            if showInvalidLabels
                label.new(bar_index, high, "L Filter NG\nclose <= EMA", style = label.style_label_down, textcolor = color.white, color = color.gray, size = size.small)
    else
        longTrigger := true
        if showTriggerLabels
            label.new(bar_index, high, "L Trigger\nPre H Body Break", style = label.style_label_down, textcolor = color.white, color = color.green, size = size.normal)

if shortPivotBreak
    shortTriggerFired := true
    shortSetupActive := false
    setupBearInvalidLevel := na
    if useEmaFilter
        if shortEmaFilterOk
            shortTrigger := true
            if showTriggerLabels
                label.new(bar_index, low, "S Trigger\nPre L Body Break\nEMA Filter OK", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.normal)
        else
            shortFilterNg := true
            shortSetupTouchHigh := na
            if showInvalidLabels
                label.new(bar_index, low, "S Filter NG\nclose >= EMA", style = label.style_label_up, textcolor = color.white, color = color.gray, size = size.small)
    else
        shortTrigger := true
        if showTriggerLabels
            label.new(bar_index, low, "S Trigger\nPre L Body Break", style = label.style_label_up, textcolor = color.white, color = color.red, size = size.normal)

longMtaMid = (htfBullZoneTop + htfBullZoneBottom) / 2.0
shortMtaMid = (htfBearZoneTop + htfBearZoneBottom) / 2.0

longStopMtaZone = htfBullZoneBottom
shortStopMtaZone = htfBearZoneTop

longStopTriggerBar = low
shortStopTriggerBar = high

longStopSetupTouch = longSetupTouchLow
shortStopSetupTouch = shortSetupTouchHigh

longStopMid = longMtaMid
shortStopMid = shortMtaMid

longSelectedStop = longStopMtaZone
shortSelectedStop = shortStopMtaZone

if slMode == "Trigger Bar"
    longSelectedStop := longStopTriggerBar
    shortSelectedStop := shortStopTriggerBar

if slMode == "Setup Touch Bar"
    longSelectedStop := longStopSetupTouch
    shortSelectedStop := shortStopSetupTouch

if slMode == "MTA Zone Mid"
    longSelectedStop := longStopMid
    shortSelectedStop := shortStopMid

longEntrySignal = barstate.isconfirmed and longTrigger and not na(longSelectedStop) and close > longSelectedStop and strategy.position_size == 0
shortEntrySignal = barstate.isconfirmed and shortTrigger and not na(shortSelectedStop) and close < shortSelectedStop and strategy.position_size == 0

if longEntrySignal
    longStop = longSelectedStop
    longRisk = close - longStop
    if longRisk > syminfo.mintick
        longLimit = close + longRisk * rr
        strategy.entry("Long", strategy.long)
        strategy.exit("Long Exit", from_entry = "Long", stop = longStop, limit = longLimit, qty_percent = 100)
        longSetupTouchLow := na

if shortEntrySignal
    shortStop = shortSelectedStop
    shortRisk = shortStop - close
    if shortRisk > syminfo.mintick
        shortLimit = close - shortRisk * rr
        strategy.entry("Short", strategy.short)
        strategy.exit("Short Exit", from_entry = "Short", stop = shortStop, limit = shortLimit, qty_percent = 100)
        shortSetupTouchHigh := na

setupState = longSetupActive ? 1 : shortSetupActive ? -1 : 0
emaFilterState = longEmaFilterOk ? 1 : shortEmaFilterOk ? -1 : 0

plot(showFilterStatePlot ? setupState : na, title = "AAA Setup State L=1 S=-1 Off=0", display = display.data_window)
plot(showFilterStatePlot ? emaFilterState : na, title = "AAA EMA Filter State L=1 S=-1", display = display.data_window)
plot(showFilterStatePlot ? (longEmaFilterOk ? 1 : 0) : na, title = "AAA L EMA Filter close>EMA", display = display.data_window)
plot(showFilterStatePlot ? (shortEmaFilterOk ? -1 : 0) : na, title = "AAA S EMA Filter close<EMA", display = display.data_window)

plot(showFilterStatePlot ? longSelectedStop : na, title = "AAA Selected Long SL", display = display.data_window)
plot(showFilterStatePlot ? shortSelectedStop : na, title = "AAA Selected Short SL", display = display.data_window)

plotshape(showSetupLabels and bullZoneTouchOnce, title = "L Setup Start", style = shape.circle, location = location.belowbar, color = color.lime, size = size.tiny, text = "L-SET")
plotshape(showSetupLabels and bearZoneTouchOnce, title = "S Setup Start", style = shape.circle, location = location.abovebar, color = color.aqua, size = size.tiny, text = "S-SET")

plotshape(showTriggerLabels and longTrigger, title = "L EMA Filter Trigger", style = shape.triangleup, location = location.belowbar, color = color.lime, size = size.small, text = "L-TRIG")
plotshape(showTriggerLabels and shortTrigger, title = "S EMA Filter Trigger", style = shape.triangledown, location = location.abovebar, color = color.red, size = size.small, text = "S-TRIG")

plotshape(showInvalidLabels and longFilterNg, title = "L EMA Filter NG", style = shape.xcross, location = location.abovebar, color = color.gray, size = size.tiny, text = "L-NG")
plotshape(showInvalidLabels and shortFilterNg, title = "S EMA Filter NG", style = shape.xcross, location = location.belowbar, color = color.gray, size = size.tiny, text = "S-NG")

alertcondition(useZoneTouchAlerts and bullZoneTouchOnce, title = "Long Setup", message = "Trigger足価格が上位足押し安値MTAゾーンに接触しました")
alertcondition(useZoneTouchAlerts and bearZoneTouchOnce, title = "Short Setup", message = "Trigger足価格が上位足戻り高値MTAゾーンに接触しました")
alertcondition(useTriggerAlerts and longTrigger, title = "Long EMA Filter Trigger", message = "Long Setup後、Pre Break Hを実体上抜けし、close > EMAを満たしました")
alertcondition(useTriggerAlerts and shortTrigger, title = "Short EMA Filter Trigger", message = "Short Setup後、Pre Break Lを実体下抜けし、close < EMAを満たしました")
